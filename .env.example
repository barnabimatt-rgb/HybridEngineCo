# Environment Variables — Nexus Automation Engine
# Copy this file to .env and fill in your values.
# See env.schema.json for full documentation.

# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/nexus
OPENAI_API_KEY=sk-your-openai-key-here

# ── AI Configuration ──────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS_PER_REQUEST=2000
RATE_LIMIT_DAILY=200

# ── Cron Schedules (UTC) ──────────────────────────────────────────────────────
TREND_SCAN_CRON=0 6 * * *
CONTENT_CRON=0 8 * * *
SEO_CRON=0 9 * * *
PRODUCT_CRON=0 10 * * 3
SAAS_CRON=0 10 * * 1
MONETIZATION_CRON=0 11 * * 1,5
BRANDING_CRON=0 12 1 * *

# ── Content Settings ──────────────────────────────────────────────────────────
DAILY_CONTENT_COUNT=4

# ── Brand ─────────────────────────────────────────────────────────────────────
BRAND_ACCENT_COLOR=#00F0FF

# ── Optional: RSS Feeds (comma-separated) ────────────────────────────────────
# RSS_FEED_URLS=https://feeds.feedburner.com/TechCrunch,https://hnrss.org/frontpage

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PATH=./logs
MEMORY_PERSIST_PATH=./memory/data
