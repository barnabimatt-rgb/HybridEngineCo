{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Automation Engine — Environment Schema",
  "description": "All required and optional environment variables for production deployment",
  "type": "object",
  "required": [
    "NODE_ENV",
    "PORT",
    "DATABASE_URL",
    "OPENAI_API_KEY"
  ],
  "properties": {
    "NODE_ENV": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Runtime environment",
      "default": "production"
    },
    "PORT": {
      "type": "string",
      "description": "HTTP server port",
      "default": "3000"
    },
    "DATABASE_URL": {
      "type": "string",
      "description": "PostgreSQL connection string (Railway Postgres plugin)",
      "pattern": "^postgres(ql)?://.+"
    },
    "OPENAI_API_KEY": {
      "type": "string",
      "description": "OpenAI API key for content generation",
      "pattern": "^sk-.+"
    },
    "OPENAI_MODEL": {
      "type": "string",
      "description": "OpenAI model to use",
      "default": "gpt-4o-mini"
    },
    "TREND_SCAN_CRON": {
      "type": "string",
      "description": "Cron expression for trend scans",
      "default": "0 6 * * *"
    },
    "CONTENT_CRON": {
      "type": "string",
      "description": "Cron expression for content generation",
      "default": "0 8 * * *"
    },
    "SEO_CRON": {
      "type": "string",
      "description": "Cron expression for SEO pipeline",
      "default": "0 9 * * *"
    },
    "PRODUCT_CRON": {
      "type": "string",
      "description": "Cron expression for product pipeline",
      "default": "0 10 * * 3"
    },
    "SAAS_CRON": {
      "type": "string",
      "description": "Cron expression for SaaS pipeline",
      "default": "0 10 * * 1"
    },
    "MONETIZATION_CRON": {
      "type": "string",
      "description": "Cron expression for monetization updates",
      "default": "0 11 * * 1,5"
    },
    "BRANDING_CRON": {
      "type": "string",
      "description": "Cron expression for branding updates",
      "default": "0 12 1 * *"
    },
    "DAILY_CONTENT_COUNT": {
      "type": "string",
      "description": "Number of content pieces to generate daily",
      "default": "4"
    },
    "RSS_FEED_URLS": {
      "type": "string",
      "description": "Comma-separated RSS feed URLs for trend scanning"
    },
    "AFFILIATE_IDS": {
      "type": "string",
      "description": "JSON object of affiliate program IDs"
    },
    "BRAND_ACCENT_COLOR": {
      "type": "string",
      "description": "Primary accent color (hex)",
      "default": "#00F0FF"
    },
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info"
    },
    "MEMORY_PERSIST_PATH": {
      "type": "string",
      "description": "Path for persistent memory store",
      "default": "./memory/data"
    },
    "LOG_PATH": {
      "type": "string",
      "description": "Path for log files",
      "default": "./logs"
    },
    "MAX_TOKENS_PER_REQUEST": {
      "type": "string",
      "description": "Token limit per OpenAI request",
      "default": "2000"
    },
    "RATE_LIMIT_DAILY": {
      "type": "string",
      "description": "Maximum OpenAI requests per day",
      "default": "200"
    }
  }
}
